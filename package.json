{
  "name": "obe-osce-speaking-trainer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "node scripts/build_app_variant.mjs",
    "build:trainer": "APP_VARIANT=trainer node scripts/build_app_variant.mjs",
    "build:editor": "APP_VARIANT=editor node scripts/build_app_variant.mjs",
    "normalize": "node scripts/normalize_patient_texts.mjs",
    "manifest": "node scripts/extract_audio_manifest.mjs",
    "audio:test": "python scripts/generate_audio.py --limit 5 --overwrite",
    "audio:all": "python scripts/generate_audio.py --overwrite",
    "audio:upload:supabase": "node scripts/upload_audio_to_supabase.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "http-server": "^14.1.1",
    "typescript": "^5.6.3"
  }
}
